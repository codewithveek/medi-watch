# =============================================================================
# MediWatch Environment Variables
# Copy this to .env and fill in your API keys
# NEVER commit .env files or API keys to git
# =============================================================================

# --- Stream ---
STREAM_API_KEY=
STREAM_API_SECRET=

# --- LLM (primary: Gemini, fallback: OpenAI) ---
GEMINI_API_KEY=
OPENAI_API_KEY=
ACTIVE_LLM=gemini                  # "gemini" | "openai"

# --- Alert channels ---
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1234567890
ALERT_PHONE_NUMBERS=               # comma-separated: +2348012345678,+2349087654321

# --- Channel toggles ---
ENABLE_VOICE_ALERTS=true
ENABLE_SMS_ALERTS=true
ENABLE_CALL_ALERTS=true
ENABLE_PUSH_ALERTS=true

# --- Detection thresholds ---
MIN_CONFIDENCE=0.75
ALERT_COOLDOWN_SECONDS=60
IMMOBILITY_TIMEOUT_MINUTES=10
TWILIO_CALL_ESCALATION_SECONDS=90

# --- Severity escalation ---
FALL_CRITICAL_FLOOR_SECONDS=30
IMMOBILITY_CRITICAL_MINUTES=20
DISTRESS_REPEAT_WINDOW_SECONDS=300

# --- Model paths ---
YOLO_MODEL_PATH=weights/yolo11n-pose.pt
MOONDREAM_DEVICE=cuda               # "cuda" | "cpu"

# --- Server ---
AGENT_PORT=8080
CORS_ORIGIN=http://localhost:5173
