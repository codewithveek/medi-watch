FROM python:3.12-slim

WORKDIR /app

# Install system dependencies for OpenCV headless + Ultralytics
# libgl1-mesa-glx was removed in Debian Trixie; libgl1 is the replacement.
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Install uv
RUN pip install uv

# Copy dependency manifests first (layer caching)
COPY pyproject.toml uv.lock README.md ./

# Install deps — then swap opencv-python for headless variant (no X11 needed)
RUN uv sync --no-dev \
    && uv pip uninstall opencv-python \
    && uv pip install opencv-python-headless

# Copy application code (after deps for better caching)
COPY agent/ ./agent/

# Create weights directory (model downloaded on first run if not mounted)
RUN mkdir -p /app/weights

# Expose port
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8080/health')"

# Run the server
CMD ["uv", "run", "python", "agent/server.py"]
